# 🌐 Backend Hub Environment Configuration (Production Sync)
PORT=10000
NODE_ENV=production

# 📡 Cloud Cluster Strategy (Turso LibSQL)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-very-long-auth-token

# 🔐 Security Protocols (JWT Synchronization)
# Set a secure random string for production
JWT_SECRET=super-secret-key-change-this-in-production

# 📶 Networking Policy (CORS Handshake Registry)
# Set to your Vercel Dashboard URL
CORS_ORIGIN=https://emp-dash-seven.vercel.app
