# Frontend Environment
# ── API Gateway ──
# Note: For local development, we use the Vite Proxy on port 5173.
# The relative baseURL (/api) in src/services/api.js automatically 
# forwards to this target.
VITE_API_URL=http://localhost:5000

# ── Feature Flags ──
VITE_ENABLE_MOCK_DATA=false
VITE_APP_VERSION=1.0.0
